{
   "manifest_version": 3,
   "name": "Auto Pan",
   "version": "1.0.0",
   "description": "Auto Pan",
   "background": {
      "service_worker": "background.js"
   },
   "action": {
      "default_popup": "popup.html"
   },
   "permissions": [
      "tabs",
      "activeTab",
      "tabCapture",
      "system.display"
   ]
}